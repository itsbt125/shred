# shred_ configuration
# Copy to .env and adjust as needed. Loaded automatically at startup
# (requires python-dotenv, which is in requirements.txt).

# Directory for database and uploads. Relative paths are resolved against the
# project root; absolute paths are used as-is. (default: data)
STORAGE_DIR=data

# Maximum file size in bytes (default: 2147483648 = 2 GB)
MAX_SIZE_BYTES=2147483648

# Refuse new uploads once free disk space would fall below this many bytes.
# Keeps headroom so the database stays writable instead of the whole service
# seizing up on a full disk. (default: 1073741824 = 1 GB)
MIN_FREE_DISK_BYTES=1073741824

# Cleanup interval in seconds (default: 300 = 5 min)
CLEANUP_INTERVAL=300

# Upload rate limit per minute per IP (default: 10)
UPLOAD_RATE_LIMIT=10

# Download rate limit per minute per IP (default: 30)
DOWNLOAD_RATE_LIMIT=30

# Abuse-report rate limit per minute per IP (default: 5)
REPORT_RATE_LIMIT=5

# Admin-API rate limit per minute per IP (default: 30)
ADMIN_RATE_LIMIT=30

# Rate window in seconds — applies to all per-IP limits above (default: 60)
RATE_WINDOW=60

# --- Chunked-upload throttling ---
# Per-upload_id chunk limit and window (DB-backed, shared across gunicorn
# workers). Bounds total chunks accepted per upload session over time.
# (defaults: 1000 chunks / 60 s)
CHUNK_RATE_LIMIT=1000
CHUNK_RATE_WINDOW=60

# Max simultaneous in-flight /api/upload/chunk requests per IP (in-memory,
# per worker). Stops one client from hogging all worker threads. (default: 8)
MAX_CONCURRENT_CHUNKS_PER_IP=8

# Global ceiling on in-progress (pending) uploads. 0 = unlimited. (default: 0)
MAX_PENDING_UPLOADS=0

# Maximum expiry a client can choose, in seconds (default: 2592000 = 30 days)
MAX_EXPIRY_SECONDS=2592000

# Maximum downloads-per-file cap (default: 1000)
MAX_DOWNLOADS_CAP=1000

# Maximum size of a pasted text share, in bytes (default: 5242880 = 5 MB)
MAX_PASTE_SIZE=5242880

# Per-request body cap Werkzeug enforces (default: 2097152 = 2 MB). Covers one
# ~1 MiB ciphertext chunk plus overhead; only raise this if you also raise the
# chunk size client-side.
MAX_UPLOAD_CHUNK_BYTES=2097152

# How long an incomplete chunked upload can sit before cleanup reaps its
# partial file and DB row, in seconds (default: 3600 = 1 hour)
PENDING_UPLOAD_TTL=3600

# How long abuse reports are kept for moderation history, in seconds
# (default: 7776000 = 90 days; 0 = keep forever)
REPORTS_RETENTION_SECONDS=7776000

# Expose each file's download count on its download page. Off by default —
# some uploaders won't want anyone holding the link to see this.
EXPOSE_DOWNLOAD_COUNT=0

# Expiry options shown in the upload dropdown. JSON array of objects with
# label, seconds, and optional default:true. Override to add/remove options:
#   EXPIRY_OPTIONS=[{"label":"30 min","seconds":1800},{"label":"1 day","seconds":86400,"default":true}]
# Default: 5 min, 15 min, 30 min, 1 hour, 1 day, 1 week, burn after reading
# EXPIRY_OPTIONS=

# Number of trusted reverse-proxy hops in front of the app.
# 0 = not behind a proxy (default): the raw socket peer is the client IP.
# Set to 1 (or more) ONLY when running behind a proxy you control, so
# X-Forwarded-For is honored for rate limiting. Do not set this if the app is
# directly reachable, or clients can spoof their IP.
TRUSTED_PROXY_COUNT=0

# Contact shown on the /terms abuse page for takedown / law-enforcement requests.
ABUSE_CONTACT=abuse@example.com

# What happens when a file is reported. "suspend" (default) pauses downloads
# immediately, pending review; "off" just records the report for the operator
# without auto-pausing. The reporter's IP is never stored either way.
REPORT_ACTION=suspend

# Privacy-by-default. When 1, the admin access log is kept in memory only (never
# persisted) and NO request IP is written to disk anywhere. Rate limiting still
# works (IPs are held in memory for the rate window only). (default: 0)
NO_LOGS=0

# --- Upload gating (optional; blank = uploads open to anyone) ---
# Downloads are never gated — the link itself is the decryption key.

# Shared secret required to upload; shows a token field on the upload page.
#   UPLOAD_TOKEN=$(python3 -c "import secrets; print(secrets.token_urlsafe(24))")
UPLOAD_TOKEN=

# Comma-separated IPs / CIDRs allowed to upload. Empty = any IP.
# Behind a reverse proxy, also set TRUSTED_PROXY_COUNT or every request will
# look like it came from the proxy.
# UPLOAD_IP_ALLOWLIST=203.0.113.4,10.0.0.0/24
UPLOAD_IP_ALLOWLIST=

# --- Rotating upload tokens (optional) ---
# When > 0, mints a fresh random upload token every N seconds; works alongside
# or instead of a static UPLOAD_TOKEN. A leaked token stops working within 2*N
# seconds. 0 = disabled. NOTE: setting this > 0 turns upload gating ON — uploads
# then require the current token. Common values: 3600 (hourly), 86400 (daily).
UPLOAD_TOKEN_ROTATION=0

# Secret for the admin panel (/admin) and for fetching the current rotating
# token via the API:
#   curl -H "X-Admin-Token: $ADMIN_TOKEN" http://127.0.0.1:5000/api/admin/token
# Generate one with:
#   ADMIN_TOKEN=$(python3 -c "import secrets; print(secrets.token_urlsafe(24))")
# If left blank while UPLOAD_TOKEN_ROTATION > 0, one is auto-generated and stored
# in the database key-value store — it is deliberately NEVER printed or logged.
# (With rotation off and this blank, the admin panel is simply disabled.)
ADMIN_TOKEN=

# --- Named invite tokens (optional) ---
# Create/revoke per-friend upload tokens from the admin panel — each is shown
# once at creation and works independently of UPLOAD_TOKEN/rotation above.
# Creating even one turns upload gating on for the whole deployment (so
# revoking your last invite doesn't silently reopen uploads to everyone).
