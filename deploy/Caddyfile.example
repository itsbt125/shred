# shred_ behind Caddy (automatic HTTPS). App runs via gunicorn on 127.0.0.1:8000.
#
#   gunicorn --workers 2 --worker-class gthread --threads 4 --bind 127.0.0.1:8000 --timeout 3600 server:app
#
# Set TRUSTED_PROXY_COUNT=1 in .env so the app sees the real client IP.
#
# Caddy sets X-Forwarded-For/-Proto and has no default body size limit, so
# unlike nginx there's nothing extra to configure for 2 GB uploads.

shred.example.com {
	# --- Privacy: no request logging ---
	# shred is a zero-knowledge, no-logs service. Discard access logs so client
	# IPs and request lines are never written to disk.
	log {
		output discard
	}

	# --- HSTS (set at the proxy, not the app) ---
	# 2 years, include subdomains. Add 'preload' only once every subdomain is
	# HTTPS-only and you intend to submit to the preload list.
	header Strict-Transport-Security "max-age=63072000; includeSubDomains"

	# gunicorn emits "Server: gunicorn" below the WSGI layer — hide it here.
	header -Server

	# /admin is already gated by ADMIN_TOKEN. Uncomment to also lock it to an IP/VPN.
	# @admin_blocked {
	#     path /admin /api/admin/*
	#     not remote_ip 203.0.113.7   # your home / VPN IP
	# }
	# respond @admin_blocked 403

	reverse_proxy 127.0.0.1:8000
}
