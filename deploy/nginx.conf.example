# shred_ behind nginx (TLS terminated here). App runs via gunicorn on 127.0.0.1:8000.
#
#   gunicorn --workers 2 --worker-class gthread --threads 4 --bind 127.0.0.1:8000 --timeout 3600 server:app
#
# (see deploy/shred.service for the actual unit — keep this comment in sync with it)
# Set TRUSTED_PROXY_COUNT=1 in .env so the app sees the real client IP.

server {
    listen 443 ssl;
    http2 on;
    server_name shred.example.com;

    ssl_certificate     /etc/letsencrypt/live/shred.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/shred.example.com/privkey.pem;

    # --- Privacy: no request logging ---
    # shred is a zero-knowledge, no-logs service. Do not persist client IPs or
    # request lines. Keep only critical errors (not per-request access lines).
    access_log off;
    error_log  /var/log/nginx/shred_error.log crit;

    # --- HSTS (set at the proxy, not the app) ---
    # 2 years, include subdomains. Only add 'preload' once you are certain every
    # subdomain is HTTPS-only and you intend to submit to the preload list.
    add_header Strict-Transport-Security "max-age=63072000; includeSubDomains" always;

    # Must be >= MAX_UPLOAD_CHUNK_BYTES (default 2MiB); overall size is
    # capped separately server-side across the whole chunked upload.
    client_max_body_size 8m;

    proxy_request_buffering off;
    proxy_buffering        off;

    proxy_read_timeout  3600s;
    proxy_send_timeout  3600s;

    # /admin is already gated by ADMIN_TOKEN. Uncomment to also lock it to an IP/VPN.
    #location ~ ^/(admin|api/admin/) {
    #    allow 203.0.113.7;   # your home / VPN IP
    #    deny all;
    #    proxy_pass http://127.0.0.1:8000;
    #    proxy_set_header Host              $host;
    #    proxy_set_header X-Real-IP         $remote_addr;
    #    proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
    #    proxy_set_header X-Forwarded-Proto $scheme;
    #}

    location / {
        proxy_pass http://127.0.0.1:8000;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}

# Redirect http -> https
server {
    listen 80;
    server_name shred.example.com;
    access_log off;
    return 301 https://$host$request_uri;
}
